{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "configMigration": true,
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Copenhagen",
  "enabledManagers": [
    "pub",
    "github-actions"
  ],
  "branchPrefix": "renovate/",
  "prCreation": "immediate",
  "dependencyDashboardApproval": false,
  "automergeType": "pr",
  "ignoreTests": false,
  "packageRules": [
    {
      "description": "Automerge grouped Flutter/Dart minor and patch updates after checks pass",
      "matchManagers": [
        "pub"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Flutter and Dart dependencies",
      "automerge": true
    },
    {
      "description": "Automerge grouped GitHub Actions minor and patch updates after checks pass",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "GitHub Actions",
      "automerge": true
    },
    {
      "description": "Keep major GitHub Actions updates separate for manual review",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "GitHub Actions major updates"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  }
}
