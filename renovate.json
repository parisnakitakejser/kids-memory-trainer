{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "configMigration": true,
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Copenhagen",
  "enabledManagers": [
    "pub",
    "github-actions"
  ],
  "branchPrefix": "renovate/",
  "prCreation": "immediate",
  "dependencyDashboardApproval": false,
  "packageRules": [
    {
      "description": "Group Flutter/Dart dependency updates",
      "matchManagers": [
        "pub"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Flutter and Dart dependencies"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "groupName": "GitHub Actions"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  }
}
